# Read the GPKG file
data <- read.csv("africa_adm1_GADM_freq_437_540_581.csv")
# Print the first few rows of the data to verify it was read correctly
# print(head(data))
data$NAME_2 <- stri_trans_general(str=gsub("-", "_", data$NAME_1), id = "Latin-ASCII")
data$NAME_2 <- stri_trans_general(str=gsub(" ", "_", data$NAME_2), id = "Latin-ASCII")
#data[] <- lapply(data, function(x) gsub("Nassa", "Niassa", x))
data$AKA <- as.numeric(data$AKA)
data$GKA <- as.numeric(data$GKA)
data$GEA <- as.numeric(data$GEA)
data$GEG <- as.numeric(data$GEG)
data$GKG <- as.numeric(data$GKG)
data$AEG <- as.numeric(data$AEG)
data$AEA <- as.numeric(data$AEA)
data$AKG <- as.numeric(data$AKG)
iso_codes <-  unique(data$iso_code)
#c("BEN", "MOZ", "CMR", "CIV", "ZMB", "GHA")
# set this to the name of your haplotype data file
haplotype_data <- read_xlsx(paste0(getwd(),"/haplotypes_combined_18_03_2025.xlsx"))
library(pacman)
p_load(malariasimulation, foreSIGHT, malariaEquilibrium, tidyr, dplyr, ggplot2,
reshape2, ggpubr, gridExtra, readxl, stringi, scene, XML, maps, readr,
here, sf)
setwd("C:/Users/IshanaAtkinson/OneDrive - London School of Hygiene and Tropical Medicine/Documents/R files/RUN_MODEL/")
# Read the GPKG file
data <- read.csv("africa_adm1_GADM_freq_437_540_581.csv")
# Print the first few rows of the data to verify it was read correctly
# print(head(data))
data$NAME_2 <- stri_trans_general(str=gsub("-", "_", data$NAME_1), id = "Latin-ASCII")
data$NAME_2 <- stri_trans_general(str=gsub(" ", "_", data$NAME_2), id = "Latin-ASCII")
#data[] <- lapply(data, function(x) gsub("Nassa", "Niassa", x))
data$AKA <- as.numeric(data$AKA)
data$GKA <- as.numeric(data$GKA)
data$GEA <- as.numeric(data$GEA)
data$GEG <- as.numeric(data$GEG)
data$GKG <- as.numeric(data$GKG)
data$AEG <- as.numeric(data$AEG)
data$AEA <- as.numeric(data$AEA)
data$AKG <- as.numeric(data$AKG)
iso_codes <-  unique(data$iso_code)
#c("BEN", "MOZ", "CMR", "CIV", "ZMB", "GHA")
# set this to the name of your haplotype data file
haplotype_data <- read_xlsx(paste0(getwd(),"/haplotypes_combined_18_03_2025.xlsx"))
# Filter out rows where PMID is "unpublished"
haplotype_data <- haplotype_data %>% filter(PMID != "unpublished")
haplotype_data <- haplotype_data %>% filter(PMID != "dont use")
# converts admin1 names into clean format that R can understand
haplotype_data$NAME_2 <- stri_trans_general(str=gsub("-", "_", haplotype_data$NAME_1), id = "Latin-ASCII")
haplotype_data$NAME_2 <- stri_trans_general(str=gsub(" ", "_", haplotype_data$NAME_2), id = "Latin-ASCII")
haplotype_proportions <- data.frame()
I_AKA_ <- I_GKA_ <- I_GEA_ <- I_GEG_ <- V_GKA_ <- V_GKG_ <- other <- c()
for (i in 1:length(iso_codes)) {
country_haplotype_data <- data %>% filter(iso_code == iso_codes[i])
admin1 <- unique(country_haplotype_data$NAME_2)
for (j in 1:length(admin1)) {
hap <- country_haplotype_data %>% filter(NAME_2 == admin1[j])
I_AKA_ <- hap$AKA
I_GKA_ <- hap$GKA
I_GEA_ <- hap$GEA
I_GEG_ <- hap$GEG
V_GKA_ <- 0 # no data for it from Foo&Flegg model
if (iso_codes[i] %in% c("BEN", "CAF","CMR", "COD", "GAB", "GHA", "NER", "NGA", "TCD" )) {
V_GKG_ <- hap$GKG
other <- sum(hap$AEG, hap$AEA, hap$AKG)
} else {
V_GKG_ <- 0 # assuming no V_GKG in other countries
other <- sum(hap$AEG, hap$AEA, hap$AKG, hap$GKG)
}
props_5sf <- round(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other), digits=5)
sum_of_prop <- sum(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other))
haplotype_proportions <- rbind(haplotype_proportions, c(iso_codes[i], admin1[j],  props_5sf, sum_of_prop))
}
}
colnames(haplotype_proportions) <- c("iso_code", "admin1", "I_AKA_", "I_GKA_", "I_GEA_", "I_GEG_", "V_GKA_", "V_GKG_", "other", "Sum of proportions" )
haplotype_proportions
names(haplotype_data)
names(haplotype_data)
##### SET UP COUNTRY / ADMIN1 NAMES #####
library(pacman)
p_load(malariasimulation, foreSIGHT, malariaEquilibrium, tidyr, dplyr, ggplot2,
reshape2, ggpubr, gridExtra, readxl, stringi, scene, XML, maps, readr,
here, sf)
setwd("C:/Users/IshanaAtkinson/OneDrive - London School of Hygiene and Tropical Medicine/Documents/R files/RUN_MODEL/")
# Read the GPKG file
data <- read.csv("africa_adm1_GADM_freq_437_540_581.csv")
# Print the first few rows of the data to verify it was read correctly
# print(head(data))
data$NAME_2 <- stri_trans_general(str=gsub("-", "_", data$NAME_1), id = "Latin-ASCII")
data$NAME_2 <- stri_trans_general(str=gsub(" ", "_", data$NAME_2), id = "Latin-ASCII")
#data[] <- lapply(data, function(x) gsub("Nassa", "Niassa", x))
data$AKA <- as.numeric(data$AKA)
data$GKA <- as.numeric(data$GKA)
data$GEA <- as.numeric(data$GEA)
data$GEG <- as.numeric(data$GEG)
data$GKG <- as.numeric(data$GKG)
data$AEG <- as.numeric(data$AEG)
data$AEA <- as.numeric(data$AEA)
data$AKG <- as.numeric(data$AKG)
iso_codes <-  unique(data$iso_code)
denom <- sum(as.integer(c(
"SAKAA", "AAKAA", "FAKAA", "SAKAS", "AAKAS", "FAKAS", "YAKAS", "SGKAA", "AGKAA", "FGKAA",
"SGKAS", "AGKAS", "SGKGS", "AGKGS", "SGEAA", "AGEAA", "AGEGA", "AAEGA", "SAEGA", "AGKGA",
"SAEAA", "SAKGA", "SAKGS", "AAKGS", "SGEGS", "SGEGA", "SGKGA", "AAEAS", "FGKAS", "FGKGA",
"FGKGS", "SAKAA_AAKAA_FAKAA", "AAKAS_FAKAS_YAKAS_SAKAS", "CGKAA_SGKAA_AGKAA", "AGKAS_SGKAS",
"SGEAA_AGEAA", "IAAKAA", "VAAKAA", "IFAKAA", "ISAKAA", "VSAKAA", "ISGKAA", "VSGKAA", "IAGKAA",
"VAGKAA", "ISGEAA", "VSGEAA", "ISGKGA", "VSGKGA", "ISGEGA", "VSGEGA", "IAGEAA", "VAGEAA",
"IAGEGA", "VAGEGA", "IAGKAS", "VAGKAS", "IAGKGS", "VAGKGS", "ISGKAS", "VSGKAS", "ISGKGS",
"VSGKGS", "IAAKGS", "other", "VAGKGA", "ICAKAA", "IHAKAA", "IAGKGA", "IYAKAS", "IAAKGA",
"IFAKAS", "ISAEAA", "ISGEAS", "IFGKAA", "ISAKAS", "IFGKAS", "IAAKAS", "I_AKAA", "I_AKAS",
"I_GKAA", "I_GKAS", "I_GEAA", "NAME_2"
)))
#c("BEN", "MOZ", "CMR", "CIV", "ZMB", "GHA")
# set this to the name of your haplotype data file
haplotype_data <- read_xlsx(paste0(getwd(),"/haplotypes_combined_18_03_2025.xlsx"))
# Filter out rows where PMID is "unpublished"
haplotype_data <- haplotype_data %>% filter(PMID != "unpublished")
haplotype_data <- haplotype_data %>% filter(PMID != "dont use")
# converts admin1 names into clean format that R can understand
haplotype_data$NAME_2 <- stri_trans_general(str=gsub("-", "_", haplotype_data$NAME_1), id = "Latin-ASCII")
haplotype_data$NAME_2 <- stri_trans_general(str=gsub(" ", "_", haplotype_data$NAME_2), id = "Latin-ASCII")
haplotype_proportions <- data.frame()
I_AKA_ <- I_GKA_ <- I_GEA_ <- I_GEG_ <- V_GKA_ <- V_GKG_ <- other <- c()
for (i in 1:length(iso_codes)) {
country_haplotype_data <- data %>% filter(iso_code == iso_codes[i])
admin1 <- unique(country_haplotype_data$NAME_2)
for (j in 1:length(admin1)) {
hap <- country_haplotype_data %>% filter(NAME_2 == admin1[j])
I_AKA_ <- hap$AKA
I_GKA_ <- hap$GKA
I_GEA_ <- hap$GEA
I_GEG_ <- hap$GEG
V_GKA_ <- 0 # no data for it from Foo&Flegg model
if (iso_codes[i] %in% c("BEN", "CAF","CMR", "COD", "GAB", "GHA", "NER", "NGA", "TCD" )) {
V_GKG_ <- hap$GKG
other <- sum(hap$AEG, hap$AEA, hap$AKG)
} else {
V_GKG_ <- 0 # assuming no V_GKG in other countries
other <- sum(hap$AEG, hap$AEA, hap$AKG, hap$GKG)
}
props_5sf <- round(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other), digits=5)
sum_of_prop <- sum(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other))
haplotype_proportions <- rbind(haplotype_proportions, c(iso_codes[i], admin1[j],  props_5sf, sum_of_prop))
}
}
colnames(haplotype_proportions) <- c("iso_code", "admin1", "I_AKA_", "I_GKA_", "I_GEA_", "I_GEG_", "V_GKA_", "V_GKG_", "other", "Sum of proportions" )
# loops over each country and admin1 area and calculates proportions for areas
# which have 6 codon data and appends to data frame
for (i in 1:length(iso_codes)) {
country_haplotype_data <- haplotype_data %>% filter(iso_code == iso_codes[i])
admin1 <- unique(country_haplotype_data$NAME_2)
# calculate 6 codon data normally but include 5 codon data in these countries
if ((iso_codes[i] %in% c("MOZ", "ZMB", "DRC"))) {
for (j in 1:length(admin1)) {
# area haplotype data
hap <- country_haplotype_data %>% filter(NAME_2 == admin1[j])
# include 5 codon genotypes for these countries
denom <- sum(as.integer(c(
hap$SAKAA, hap$AAKAA, hap$FAKAA, hap$SAKAS, hap$AAKAS, hap$FAKAS, hap$YAKAS, hap$SGKAA, hap$AGKAA, hap$FGKAA,
hap$SGKAS, hap$AGKAS, hap$SGKGS, hap$AGKGS, hap$SGEAA, hap$AGEAA, hap$AGEGA, hap$AAEGA, hap$SAEGA, hap$AGKGA,
hap$SAEAA, hap$SAKGA, hap$SAKGS, hap$AAKGS, hap$SGEGS, hap$SGEGA, hap$SGKGA, hap$AAEAS, hap$FGKAS, hap$FGKGA,
hap$FGKGS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$CGKAA_SGKAA_AGKAA, hap$AGKAS_SGKAS,
hap$SGEAA_AGEAA, hap$IAAKAA, hap$VAAKAA, hap$IFAKAA, hap$ISAKAA, hap$VSAKAA, hap$ISGKAA, hap$VSGKAA, hap$IAGKAA,
hap$VAGKAA, hap$ISGEAA, hap$VSGEAA, hap$ISGKGA, hap$VSGKGA, hap$ISGEGA, hap$VSGEGA, hap$IAGEAA, hap$VAGEAA,
hap$IAGEGA, hap$VAGEGA, hap$IAGKAS, hap$VAGKAS, hap$IAGKGS, hap$VAGKGS, hap$ISGKAS, hap$VSGKAS, hap$ISGKGS,
hap$VSGKGS, hap$IAAKGS, hap$other, hap$VAGKGA, hap$ICAKAA, hap$IHAKAA, hap$IAGKGA, hap$IYAKAS, hap$IAAKGA,
hap$IFAKAS, hap$ISAEAA, hap$ISGEAS, hap$IFGKAA, hap$ISAKAS, hap$IFGKAS, hap$IAAKAS, hap$I_AKAA, hap$I_AKAS,
hap$I_GKAA, hap$I_GKAS, hap$I_GEAA
)), na.rm = TRUE)
if (denom < 31) { next} else {
I_AKA_ <- sum(as.integer(c(hap$IAAKAA, hap$IFAKAA, hap$ISAKAA, hap$ICAKAA, hap$IHAKAA, hap$IYAKAS, hap$IFAKAS, hap$ISAKAS, hap$IAAKAS,hap$SAKAA, hap$AAKAA, hap$FAKAA, hap$SAKAS, hap$AAKAS, hap$FAKAS, hap$YAKAS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$I_AKAA, hap$I_AKAS)), na.rm=TRUE) / denom
I_GKA_ <- sum(as.integer(c(hap$ISGKAA, hap$IAGKAA, hap$IAGKAS, hap$ISGKAS, hap$IFGKAA, hap$IFGKAS,hap$SGKAA, hap$AGKAA, hap$FGKAA, hap$SGKAS, hap$AGKAS, hap$FGKAS, hap$CGKAA_SGKAA_AGKAA, hap$AGKAS_SGKAS, hap$I_GKAA, hap$I_GKAS)), na.rm=TRUE) / denom
I_GEA_ <- sum(as.integer(c(hap$ISGEAA, hap$IAGEAA, hap$ISGEAS, hap$SGEAA, hap$AGEAA, hap$SGEAA_AGEAA, hap$I_GEAA)), na.rm=TRUE) / denom
I_GEG_ <- sum(as.integer(c(hap$ISGEGA, hap$IAGEGA, hap$AGEGA, hap$SGEGS, hap$SGEGA)), na.rm=TRUE) / denom
V_GKA_ <- sum(as.integer(c(hap$VSGKAA, hap$VAGKAA, hap$VAGKAS, hap$VSGKAS)), na.rm=TRUE) / denom
V_GKG_ <- sum(as.integer(c(hap$VSGKGA, hap$VAGKGS, hap$VSGKGS, hap$VAGKGA)), na.rm=TRUE) / denom
other <- sum(as.integer(c(hap$VAAKAA,  hap$VSAKAA, hap$VSGEAA, hap$ISGKGA, hap$VSGEGA, hap$VAGEAA, hap$VAGEGA, hap$IAGKGS, hap$ISGKGS, hap$IAAKGS, hap$other, hap$IAGKGA, hap$IAAKGA, hap$ISAEAA, hap$SGKGS, hap$AGKGS, hap$AAEGA, hap$SAEGA, hap$AGKGA, hap$SAEAA, hap$SAKGA, hap$SAKGS, hap$AAKGS, hap$SGKGA, hap$AAEAS, hap$FGKGA, hap$FGKGS)), na.rm=TRUE) / denom
props_5sf <- round(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other), digits=5)
sum_of_prop <- sum(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other))
# check proportions add to 1
if (is.nan(sum_of_prop) == TRUE) {
print(paste0("Summation of proportions for ", admin1[j], " in ", iso_codes[i], " cannot be calculated due to lack of 6-codon data"))
} else {
print(paste0("Summation of proportions for ", admin1[j], " in ", iso_codes[i], " is: ", sum_of_prop))
haplotype_proportions[(haplotype_proportions$iso_code == iso_codes[i] & haplotype_proportions$admin1 == admin1[j]),] <- c(iso_codes[i], admin1[j],  props_5sf, sum_of_prop)
}
}
}
} else {
for (j in 1:length(admin1)) {
# area haplotype data
hap <- country_haplotype_data %>% filter(NAME_2 == admin1[j])
denom <- sum(as.integer(c(
hap$SAKAA, hap$AAKAA, hap$FAKAA, hap$SAKAS, hap$AAKAS, hap$FAKAS, hap$YAKAS, hap$SGKAA, hap$AGKAA, hap$FGKAA,
hap$SGKAS, hap$AGKAS, hap$SGKGS, hap$AGKGS, hap$SGEAA, hap$AGEAA, hap$AGEGA, hap$AAEGA, hap$SAEGA, hap$AGKGA,
hap$SAEAA, hap$SAKGA, hap$SAKGS, hap$AAKGS, hap$SGEGS, hap$SGEGA, hap$SGKGA, hap$AAEAS, hap$FGKAS, hap$FGKGA,
hap$FGKGS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$CGKAA_SGKAA_AGKAA, hap$AGKAS_SGKAS,
hap$SGEAA_AGEAA, hap$IAAKAA, hap$VAAKAA, hap$IFAKAA, hap$ISAKAA, hap$VSAKAA, hap$ISGKAA, hap$VSGKAA, hap$IAGKAA,
hap$VAGKAA, hap$ISGEAA, hap$VSGEAA, hap$ISGKGA, hap$VSGKGA, hap$ISGEGA, hap$VSGEGA, hap$IAGEAA, hap$VAGEAA,
hap$IAGEGA, hap$VAGEGA, hap$IAGKAS, hap$VAGKAS, hap$IAGKGS, hap$VAGKGS, hap$ISGKAS, hap$VSGKAS, hap$ISGKGS,
hap$VSGKGS, hap$IAAKGS, hap$other, hap$VAGKGA, hap$ICAKAA, hap$IHAKAA, hap$IAGKGA, hap$IYAKAS, hap$IAAKGA,
hap$IFAKAS, hap$ISAEAA, hap$ISGEAS, hap$IFGKAA, hap$ISAKAS, hap$IFGKAS, hap$IAAKAS, hap$I_AKAA, hap$I_AKAS,
hap$I_GKAA, hap$I_GKAS, hap$I_GEAA
)), na.rm = TRUE)
if (denom < 31) {next} else {
I_AKA_ <- sum(as.integer(c(hap$IAAKAA, hap$IFAKAA, hap$ISAKAA, hap$ICAKAA, hap$IHAKAA, hap$IYAKAS, hap$IFAKAS, hap$ISAKAS, hap$IAAKAS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$I_AKAA, hap$I_AKAS)), na.rm=TRUE) / denom
I_GKA_ <- sum(as.integer(c(hap$ISGKAA, hap$IAGKAA, hap$IAGKAS, hap$ISGKAS, hap$IFGKAA, hap$IFGKAS, hap$I_GKAA, hap$I_GKAS)), na.rm=TRUE) / denom
I_GEA_ <- sum(as.integer(c(hap$ISGEAA, hap$IAGEAA, hap$ISGEAS, hap$I_GEAA)), na.rm=TRUE) / denom
I_GEG_ <- sum(as.integer(c(hap$ISGEGA, hap$IAGEGA)), na.rm=TRUE) / denom
V_GKA_ <- sum(as.integer(c(hap$VSGKAA, hap$VAGKAA, hap$VAGKAS, hap$VSGKAS)), na.rm=TRUE) / denom
V_GKG_ <- sum(as.integer(c(hap$VSGKGA, hap$VAGKGS, hap$VSGKGS, hap$VAGKGA)), na.rm=TRUE) / denom
other <- sum(as.integer(c(hap$VAAKAA,  hap$VSAKAA, hap$VSGEAA, hap$ISGKGA, hap$VSGEGA, hap$VAGEAA, hap$VAGEGA, hap$IAGKGS, hap$ISGKGS, hap$IAAKGS, hap$other, hap$IAGKGA, hap$IAAKGA, hap$ISAEAA)), na.rm=TRUE) / denom
props_5sf <- round(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other), digits=5)
sum_of_prop <- sum(c(I_AKA_, I_GKA_, I_GEA_, I_GEG_, V_GKA_, V_GKG_, other))
# check proportions add to 1
if (is.nan(sum_of_prop) == TRUE) {
print(paste0("Summation of proportions for ", admin1[j], " in ", iso_codes[i], " cannot be calculated due to lack of 6-codon data"))
} else {
print(paste0("Summation of proportions for ", admin1[j], " in ", iso_codes[i], " is: ", sum_of_prop))
haplotype_proportions[(haplotype_proportions$iso_code == iso_codes[i] & haplotype_proportions$admin1 == admin1[j]),] <- c(iso_codes[i], admin1[j],  props_5sf, sum_of_prop)
}
}
}
}
}
write.csv(haplotype_proportions, paste0(getwd(), "/haplotype_data_final.csv"))
View(haplotype_proportions)
length(c(hap$IAAKAA, hap$IFAKAA, hap$ISAKAA, hap$ICAKAA, hap$IHAKAA, hap$IYAKAS, hap$IFAKAS, hap$ISAKAS, hap$IAAKAS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$I_AKAA, hap$I_AKAS))
a<- c(hap$IAAKAA, hap$IFAKAA, hap$ISAKAA, hap$ICAKAA, hap$IHAKAA, hap$IYAKAS, hap$IFAKAS, hap$ISAKAS, hap$IAAKAS, hap$SAKAA_AAKAA_FAKAA, hap$AAKAS_FAKAS_YAKAS_SAKAS, hap$I_AKAA, hap$I_AKAS)
length(a)
